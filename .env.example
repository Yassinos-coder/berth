# ─────────────────────────────────────────────────────────────
# Berth — single source of environment config for the whole
# monorepo. Every app reads from this root file:
#   • berth-ui     → Vite (envDir points here; only VITE_* vars
#                    are exposed to the browser bundle)
#   • berth-server → NestJS ConfigModule (envFilePath: ../../.env)
#   • berth-agent  → dotenvy loads ../../.env at startup
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Shared ───────────────────────────────────────────────────
NODE_ENV=development

# ── berth-ui (browser — MUST be prefixed VITE_) ──────────────
# Base path/URL the dashboard calls. In dev, Vite proxies /api
# to the panel (see vite.config.ts).
VITE_API_BASE=/api
# Gate the whole app behind auth once berth-server is live.
VITE_ENFORCE_AUTH=false

# ── berth-server (NestJS panel — server-only, never exposed) ─
PORT=4000
# Local Postgres container settings. If the backend runs on your host,
# keep POSTGRES_HOST=localhost. Use POSTGRES_HOST=postgres only when the
# backend itself runs in Docker on the same Compose network.
POSTGRES_USER=berth
POSTGRES_PASSWORD=berth
POSTGRES_DB=berth
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://berth:berth@localhost:5432/berth
# Redis backing store for nestjs-shield (rate limit / auto-ban).
REDIS_URL=redis://localhost:6379
# Session signing.
JWT_SECRET=replace-with-a-long-random-string
# Envelope-encryption master key for secrets at rest (32-byte base64).
BERTH_MASTER_KEY=replace-with-32-byte-base64-key
# GitHub App / OAuth + webhook verification.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
# Port the agent-facing WebSocket (mTLS) listens on.
AGENT_WS_PORT=4443
# Public WebSocket URL agents should use when enrolling from other servers.
BERTH_PUBLIC_PANEL_URL=wss://panel.example.com:4443
# Public git URL the hosted installer can clone to build the agent.
BERTH_AGENT_REPO_URL=https://github.com/your-org/berth.git
# Panel CA used to issue/verify agent client certs.
BERTH_CA_CERT_PATH=./certs/ca.pem
BERTH_CA_KEY_PATH=./certs/ca-key.pem

# ── berth-agent (Rust — server-only) ─────────────────────────
# Panel URL the agent dials out to over WebSocket/mTLS.
BERTH_PANEL_URL=wss://localhost:4443
# One-time bootstrap enrollment token (burned after first use).
BERTH_BOOTSTRAP=
